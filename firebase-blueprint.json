{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A natural health or wellness product",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Health benefits and usage" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "Category e.g. Honey, Seeds" },
        "images": { "type": "array", "items": { "type": "string" } },
        "inventory": { "type": "integer" },
        "origin": { "type": "string", "description": "Source region e.g. Sundarbans" },
        "purity": { "type": "string", "description": "Lab tested results" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "integer" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A craft tutorial or artist spotlight",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "type": { "enum": ["tutorial", "spotlight", "news"] },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "content", "author", "type"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all handmade crafts"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Subcollection of reviews for a specific product"
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of tutorials and spotlights"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and metadata"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Secure order tracking and history"
    }
  }
}
