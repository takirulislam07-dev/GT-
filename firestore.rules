rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // 1. Check for specific owner email (Bootstrap)
      // 2. Check for admin role in user profile
      // 3. Check dedicated admins collection
      return isSignedIn() && (
        (request.auth.token.email == 'takirulislam07@gmail.com' && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'artist', 'category', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.price is number && data.price > 0 &&
             data.artist is string && data.artist.size() > 0 &&
             data.category is string &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'rating', 'comment', 'createdAt']) &&
             data.productId is string &&
             data.userId == request.auth.uid &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list &&
             data.total is number &&
             data.status in ['pending', 'processing', 'shipped', 'delivered'] &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    // Products
    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true; // Public listing is often required for SEO/Shop browsing
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();

      // Nested Reviews
      match /reviews/{reviewId} {
        allow get: if isValidId(reviewId);
        allow list: if true;
        allow create: if isEmailVerified() && isValidReview(incoming()) && isValidId(reviewId) && exists(/databases/$(database)/documents/products/$(productId));
        allow update: if isOwner(existing().userId) && isValidReview(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']);
        allow delete: if isOwner(existing().userId) || isAdmin();
      }
    }

    // Blog Posts
    match /blogPosts/{postId} {
      allow get: if isValidId(postId);
      allow list: if true;
      allow create, update, delete: if isAdmin() && isValidId(postId);
    }

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'user';
      allow update: if isOwner(userId) && incoming().role == existing().role;
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidOrder(incoming()) && isValidId(orderId);
      allow update: if isAdmin(); // Only admins can update status
    }
  }
}
